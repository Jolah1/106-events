# Required
DATABASE_URL=postgres://jolah@localhost:5433/events106_dev

# Comma-separated admin emails, seeded on startup. Sign-in is invite-only, so
# without at least one admin here nobody can log in to invite anyone else.
ADMIN_EMAILS=you@106.events

# Where the API listens
BIND_ADDR=0.0.0.0:8080

# Origin of the organizer dashboard (magic links point here)
APP_BASE_URL=http://localhost:5173

# Origin of this server (public event pages, webhook URLs)
PUBLIC_BASE_URL=http://localhost:8080

# SMTP for magic-link email, e.g. smtps://user:pass@smtp.example.com:465
# Leave unset in development: links are logged and returned to the login page.
# SMTP_URL=
EMAIL_FROM="106 Events <no-reply@106.events>"

# Set true behind HTTPS in production
COOKIE_SECURE=false

# Shared secret for the inbound WhatsApp/SMS webhook. When set, requests to
# /api/webhooks/inbound must carry it in the X-Webhook-Secret header. Leave
# unset in development; always set it in production.
# WEBHOOK_SECRET=

# Serve the built dashboard from this directory (production single-binary deploy)
# DASHBOARD_DIST=../dashboard/dist

# Returns the magic link in the sign-in response instead of emailing it, so the
# flow works locally with no SMTP. Only takes effect when SMTP_URL is unset.
# NEVER set this in production: it hands a working sign-in link to anyone who
# asks for one.
ALLOW_DEV_LOGIN=true
