  "query": "\n            SELECT u.id, u.email, u.phone, u.name, u.role, u.created_at\n            FROM sessions s\n            JOIN users u ON u.id = s.user_id\n            WHERE s.token_hash = $1 AND s.expires_at > now()\n            ",
