{
  "db_name": "PostgreSQL",
  "query": "SELECT c.attendee_id, c.checked_in_at, c.over_allowance, c.synced_offline,\n                a.head_index, g.name\n         FROM check_ins c\n         JOIN attendees a ON a.id = c.attendee_id\n         JOIN guests g ON g.id = a.guest_id\n         WHERE c.sub_event_id = $1\n         ORDER BY c.checked_in_at DESC",
