  "db_name": "PostgreSQL",
  "query": "\n        SELECT\n            count(*) AS \"vendor_count!\",\n            COALESCE(sum(cost_kobo), 0)::bigint AS \"cost!\",\n            COALESCE(sum(amount_paid_kobo), 0)::bigint AS \"paid!\",\n            COALESCE(sum(greatest(cost_kobo - amount_paid_kobo, 0)), 0)::bigint AS \"outstanding!\"\n        FROM vendors\n        WHERE event_id = $1\n        ",
