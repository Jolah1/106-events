{
  "db_name": "PostgreSQL",
  "query": "\n        SELECT DISTINCT g.id, g.name, g.phone AS \"phone!\", g.rsvp_token\n        FROM guests g\n        JOIN guest_invites gi ON gi.guest_id = g.id\n        WHERE g.event_id = $1\n          AND gi.rsvp_status = 'pending'\n          AND g.phone IS NOT NULL\n        ORDER BY g.name\n        ",
